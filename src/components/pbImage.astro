---
import { getImageUrl } from '../backend.mjs';
import { Image } from "astro:assets";

const { 
    record, 
    recordImage, 
    height = 300, 
    width = 400,
} = Astro.props;


const imageURL = await getImageUrl(record, recordImage);
---

{imageURL && 
    <Image
        src={imageURL}
        alt={record.nomMaison || 'Image'}
        height={height}
        width={width}
    />
}
