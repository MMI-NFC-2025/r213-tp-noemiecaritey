---
const { offre } = Astro.props;
---

<div
    class="border border-gray-200 rounded-lg p-6 shadow-md hover:shadow-lg hover:-translate-y-1 transition-all cursor-pointer"
>
    <img src={`/${offre.imgUrl}`} alt={offre.nomMaison} class="w-full h-48 object-cover rounded mb-4" />
    
    <div class="flex items-center gap-2 mb-2">
        <strong class="text-lg">{offre.nomMaison}</strong>
    </div>
    <p class="text-gray-600 text-sm mb-4">{offre.adresse}</p>
    <p class="text-gray-600 text-sm mb-4">${offre.prix} - {offre.surface} m² - {offre.nbChambres} chambres - {offre.nbSdb} sdb</p>
    <button class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded text-sm transition-colors">
        Favori
    </button>
</div>
