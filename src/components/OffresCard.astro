---
import PbImage from '../components/pbImage.astro'; 

const { offre } = Astro.props;
---

<div
    class="border border-gray-200 rounded-lg p-6 shadow-md hover:shadow-lg hover:-translate-y-1 transition-all cursor-pointer"
>
    <PbImage 
        record={offre} 
        recordImage={offre.image[0]} 
        class="w-full h-48 object-cover rounded mb-4" 
    />

    <div class="flex items-center gap-2 mb-2">
        <strong class="text-lg">{offre.nom_maison}</strong>
    </div>
</div>
