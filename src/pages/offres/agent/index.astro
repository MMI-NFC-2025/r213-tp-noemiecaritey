---
import Layout from '../../layouts/Layout.astro';
import { getAgents } from '../../backend.mjs';

const agents = await getAgents();
---

<Layout title="Agents">
  <h1 class="text-4xl font-black mb-8 text-center">
    Liste des agents
  </h1>

  <ul class="space-y-4">
    {agents.map((agent) => (
      <li>
        <a
          href={`/agents/${agent.id}`}
          class="text-orange-600 underline"
        >
          {agent.nom}
        </a>
      </li>
    ))}
  </ul>
</Layout>