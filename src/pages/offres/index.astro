---
import "../../styles/global.css";
import OffreCard from "../../components/OffresCard.astro";
import { getOffres, getOffresSupSurface, getOffresinfprix } from "../../backend.mjs";
import Layout from "../../layouts/Layout.astro";

const offres = await getOffres();
const surfaces = await getOffresSupSurface(80);
const prix = await getOffresinfprix(500000);
---

<Layout title="Offres">
  <h1 class="text-2xl font-bold mb-6">Offres disponibles</h1>
  
  <div class="flex gap-4 mb-6">
    <a href="/offres/surface/80" class="text-blue-600 hover:underline font-medium">< 80 m²</a>
    <a href="/offres/prix/500000" class="text-green-600 hover:underline font-medium"> >500k €</a>
  </div>
  
  <button id="favori-button" class="bg-gray-800 text-white px-6 py-2 rounded hover:bg-gray-900 mb-6">Afficher les favoris</button>
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {offres.map((offre) => 
      <div class="offre" data-favori={offre.favori.toString()}>
        <OffreCard offre={offre} />
      </div>
    )}
  </div>
</Layout>

<script>
    //@ts-nocheck
    const button = document.getElementById('favori-button');
    let showOnlyFavorites = false;
    
    button?.addEventListener('click', () => {
        showOnlyFavorites = !showOnlyFavorites;
        const offres = document.querySelectorAll('.offre');
        
        offres.forEach(offre => {
            const isFavori = offre.dataset.favori === 'true';
            
            if (showOnlyFavorites) {
                offre.style.display = isFavori ? '' : 'none';
                button.textContent = 'Afficher tout';
            } else {
                offre.style.display = '';
                button.textContent = 'Afficher les favoris';
            }
        });
    });
</script>


